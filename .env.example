PORT=3000

# Security (HMAC Secret for verifying events from main app)
WEBHOOK_SECRET=your_super_secret_hmac_key_here

# SendGrid Configuration
SENDGRID_API_KEY=SG.your_sendgrid_key_here
SENDGRID_FROM_EMAIL=alerts@voraprotocol.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Sandbox Mode (Set to true to test without sending real emails/SMS)
SANDBOX_MODE=true
